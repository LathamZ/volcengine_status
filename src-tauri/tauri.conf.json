{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Volcengine Status",
  "version": "1.0.1",
  "identifier": "com.lathamzhao.volcenginestatus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Volcengine Status",
        "width": 400,
        "height": 540,
        "minWidth": 380,
        "minHeight": 320,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "visibleOnAllWorkspaces": true,
        "shadow": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState",
          "radius": 14
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "exceptionDomain": "localhost"
    },
    "category": "DeveloperTool",
    "shortDescription": "Volcengine Ark plan usage in your menu bar",
    "longDescription": "A macOS menu bar app that shows Volcengine Ark Agent Plan and Coding Plan usage, sourced from the local arkcli SSO session."
  }
}
